<%- include('../../partials/header') %>
<div class="main-content">
  <%- include('../../partials/topnav') %>
  <div class="page-content">
    <div class="page-header">
      <h4><i class="bi bi-gear me-2"></i>Job 2 - Operator N2</h4>
    </div>

    <div class="profile-section">
      <h3><i class="bi bi-info-circle me-2"></i>Deskripsi Job Operator N2</h3>
      <% if (description.length > 0) { %>
        <p class="text-muted"><%= description[0].description %></p>
      <% } %>
    </div>

    <div class="profile-section">
      <h3><i class="bi bi-cpu me-2"></i>Profil Mesin</h3>
      <div class="row">
        <% machines.forEach(function(m) { %>
        <div class="col-md-4 mb-3">
          <div class="card">
            <div class="card-body text-center">
              <i class="bi bi-cpu" style="font-size: 48px; color: #1e3c72;"></i>
              <h5 class="mt-2"><%= m.name %></h5>
              <p class="text-muted small"><%= m.description %></p>
            </div>
          </div>
        </div>
        <% }); %>
      </div>
    </div>

    <div class="row">
      <div class="col-md-4 mb-3">
        <a href="/job2/checklist/n2_generator" class="card text-decoration-none">
          <div class="card-body text-center">
            <i class="bi bi-clipboard-check" style="font-size: 36px; color: #28a745;"></i>
            <h5 class="mt-2">Checklist N2 Generator</h5>
          </div>
        </a>
      </div>
      <div class="col-md-4 mb-3">
        <a href="/job2/checklist/kompressor03" class="card text-decoration-none">
          <div class="card-body text-center">
            <i class="bi bi-clipboard-check" style="font-size: 36px; color: #28a745;"></i>
            <h5 class="mt-2">Checklist Kompressor 03</h5>
          </div>
        </a>
      </div>
      <div class="col-md-4 mb-3">
        <a href="/job2/checklist/kompressor04" class="card text-decoration-none">
          <div class="card-body text-center">
            <i class="bi bi-clipboard-check" style="font-size: 36px; color: #28a745;"></i>
            <h5 class="mt-2">Checklist Kompressor 04</h5>
          </div>
        </a>
      </div>
      <div class="col-md-4 mb-3">
        <a href="/job2/checklist/lvmdp" class="card text-decoration-none">
          <div class="card-body text-center">
            <i class="bi bi-clipboard-check" style="font-size: 36px; color: #28a745;"></i>
            <h5 class="mt-2">Checklist LVMDP</h5>
          </div>
        </a>
      </div>
      <div class="col-md-4 mb-3">
        <a href="/job2/checklist/air_tandon" class="card text-decoration-none">
          <div class="card-body text-center">
            <i class="bi bi-clipboard-check" style="font-size: 36px; color: #28a745;"></i>
            <h5 class="mt-2">Checklist Air Tandon</h5>
          </div>
        </a>
      </div>
      <div class="col-md-4 mb-3">
        <a href="/job2/warning" class="card text-decoration-none">
          <div class="card-body text-center">
            <i class="bi bi-exclamation-triangle" style="font-size: 36px; color: #ffc107;"></i>
            <h5 class="mt-2">Input Warning Mesin</h5>
          </div>
        </a>
      </div>
      <div class="col-md-4 mb-3">
        <a href="/job2/instructions" class="card text-decoration-none">
          <div class="card-body text-center">
            <i class="bi bi-file-earmark-pdf" style="font-size: 36px; color: #dc3545;"></i>
            <h5 class="mt-2">Working Instruction</h5>
          </div>
        </a>
      </div>
    </div>
  </div>
</div>
<%- include('../../partials/footer') %>
