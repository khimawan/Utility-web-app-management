<%- include('../../partials/header') %>
  <%- include('../../partials/topnav') %>
  <div class="page-content">
    <div class="page-header d-flex justify-content-between align-items-center flex-wrap gap-2">
      <h4><i class="bi bi-box-seam me-2"></i>Pemakaian Part dan Bahan</h4>
      <div class="d-flex gap-2">
        <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addPemakaianModal"><i class="bi bi-plus-circle me-1"></i>Tambah Pemakaian</button>
      </div>
    </div>

    <div class="card">
      <div class="card-body">
        <div class="delete-selected-bar">
          <button class="btn btn-sm btn-outline-danger" onclick="deleteSelected('/pemakaian/delete-multiple')"><i class="bi bi-trash me-1"></i>Hapus Terpilih</button>
        </div>
        <div class="table-responsive scrollable-table">
          <table class="table table-striped table-hover">
            <thead>
              <tr>
                <th><input type="checkbox" class="select-all-checkbox"></th>
                <th>Nama Pemakai</th>
                <th>Part & Bahan</th>
                <th>Jumlah</th>
                <th>Project</th>
                <th>Tanggal</th>
                <th>Aksi</th>
              </tr>
            </thead>
            <tbody>
              <% records.forEach(function(r) { %>
              <tr>
                <td><input type="checkbox" class="row-checkbox" value="<%= r.id %>"></td>
                <td>
                  <%
                    var memberIds = JSON.parse(r.member_ids || '[]');
                    var memberNames = memberIds.map(function(mid) {
                      var found = members.find(function(m) { return m.id === mid; });
                      return found ? found.name : '';
                    }).filter(function(n) { return n; });
                  %>
                  <%= memberNames.join(', ') %>
                </td>
                <td>
                  <%
                    var itemList = JSON.parse(r.items || '[]');
                    var itemNames = itemList.map(function(i) { return i.name || ''; }).filter(function(n) { return n; });
                  %>
                  <%= itemNames.join(', ') %>
                </td>
                <td>
                  <%
                    var quantities = itemList.map(function(i) { return i.qty || i.quantity || 0; });
                  %>
                  <%= quantities.join(', ') %>
                </td>
                <td><%= r.project_name || '-' %></td>
                <td><%= r.created_at %></td>
                <td>
                  <form method="POST" action="/pemakaian/<%= r.id %>/delete" style="display:inline;" class="delete-btn-form">
                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                  </form>
                </td>
              </tr>
              <% }); %>
              <% if (records.length === 0) { %>
              <tr><td colspan="7" class="text-center text-muted">Belum ada data</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <div class="modal fade" id="addPemakaianModal" tabindex="-1">
      <div class="modal-dialog modal-lg">
        <div class="modal-content">
          <form method="POST" action="/pemakaian">
            <div class="modal-header">
              <h5 class="modal-title">Tambah Pemakaian</h5>
              <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
              <div class="mb-3">
                <label class="form-label">Nama Pemakai</label>
                <input type="text" class="form-control mb-2" id="searchMember" placeholder="Cari pemakai..." oninput="filterMember(this.value)">
                <div style="max-height:200px;overflow-y:auto;border:1px solid #dee2e6;border-radius:4px;padding:8px;">
                  <% members.forEach(function(m) { %>
                  <div class="form-check member-item" data-name="<%= m.name.toLowerCase() %>">
                    <input class="form-check-input member-checkbox" type="checkbox" value="<%= m.id %>" data-membername="<%= m.name %>" onchange="getSelectedMembers()">
                    <label class="form-check-label"><%= m.name %></label>
                  </div>
                  <% }); %>
                </div>
                <input type="hidden" name="member_ids" id="selectedMembers" value="[]">
              </div>
              <div class="mb-3">
                <label class="form-label">Part dan Bahan yang dipakai</label>
                <input type="text" class="form-control mb-2" id="searchItem" placeholder="Cari part/bahan..." oninput="filterItem(this.value)">
                <div style="max-height:200px;overflow-y:auto;border:1px solid #dee2e6;border-radius:4px;padding:8px;">
                  <% items.forEach(function(item) { %>
                  <div class="form-check item-pakai" data-name="<%= item.item_name.toLowerCase() %>">
                    <div class="d-flex align-items-center gap-2">
                      <input class="form-check-input item-checkbox" type="checkbox" value="<%= item.id %>" data-itemname="<%= item.item_name %>" onchange="getSelectedItems()">
                      <label class="form-check-label flex-grow-1"><%= item.item_name %> - <%= item.specification || '-' %> (stok: <%= item.quantity %>)</label>
                      <input type="number" class="form-control form-control-sm item-qty" style="width:70px;" min="0" value="1" placeholder="Jumlah" onchange="getSelectedItems()">
                    </div>
                  </div>
                  <% }); %>
                </div>
                <input type="hidden" name="items" id="selectedItems" value="[]">
              </div>
              <div class="mb-3">
                <label class="form-label">Project yang membutuhkan</label>
                <input type="text" name="project_name" class="form-control" placeholder="Nama project" required>
              </div>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
              <button type="submit" class="btn btn-primary">Simpan</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>

<script>
function filterMember(query) {
  var q = query.toLowerCase();
  document.querySelectorAll('#addPemakaianModal .member-item').forEach(function(el) {
    el.style.display = el.dataset.name.includes(q) ? '' : 'none';
  });
}

function filterItem(query) {
  var q = query.toLowerCase();
  document.querySelectorAll('#addPemakaianModal .item-pakai').forEach(function(el) {
    el.style.display = el.dataset.name.includes(q) ? '' : 'none';
  });
}

function getSelectedMembers() {
  var selected = [];
  document.querySelectorAll('#addPemakaianModal .member-checkbox:checked').forEach(function(cb) {
    selected.push(parseInt(cb.value));
  });
  document.getElementById('selectedMembers').value = JSON.stringify(selected);
}

function getSelectedItems() {
  var selected = [];
  document.querySelectorAll('#addPemakaianModal .item-checkbox:checked').forEach(function(cb) {
    var container = cb.closest('.item-pakai');
    var qtyInput = container ? container.querySelector('.item-qty') : null;
    var qty = qtyInput ? parseInt(qtyInput.value) || 1 : 1;
    selected.push({ id: parseInt(cb.value), qty: qty, name: cb.dataset.itemname });
  });
  document.getElementById('selectedItems').value = JSON.stringify(selected);
}
</script>
<%- include('../../partials/footer') %>
