<%- include('../../partials/header') %>
  <%- include('../../partials/topnav') %>
  <div class="page-content">
    <div class="page-header d-flex justify-content-between align-items-center">
      <h4><i class="bi bi-gear me-2"></i>Edit Landing Page Utility</h4>
      <a href="/utility" class="btn btn-outline-primary btn-sm" target="_blank"><i class="bi bi-eye me-1"></i>Lihat Halaman Publik</a>
    </div>

    <div class="card">
      <div class="card-body">
        <form method="POST" action="/awal/admin/landing-content" enctype="multipart/form-data">
          <div class="mb-3">
            <label class="form-label">Judul Utama</label>
            <input type="text" name="welcome_title" class="form-control" value="<%= content.welcome_title ? content.welcome_title.content_value : 'PT VDNI Utility Management' %>">
          </div>
          <div class="mb-3">
            <label class="form-label">Sub Judul</label>
            <input type="text" name="welcome_subtitle" class="form-control" value="<%= content.welcome_subtitle ? content.welcome_subtitle.content_value : 'Sistem Utility Management' %>">
          </div>
          <div class="mb-3">
            <label class="form-label">Deskripsi</label>
            <textarea name="welcome_description" class="form-control" rows="3"><%= content.welcome_description ? content.welcome_description.content_value : 'Sistem manajemen utility untuk monitoring dan pengajuan bantuan teknis' %></textarea>
          </div>
          <div class="mb-3">
            <label class="form-label">Gambar Saat Ini</label>
            <div class="mb-2">
              <% if (content.welcome_image && content.welcome_image.content_image) { %>
                <img src="<%= content.welcome_image.content_image %>" style="max-height:150px;" class="rounded">
              <% } else { %>
                <span class="text-muted">Tidak ada gambar</span>
              <% } %>
            </div>
          </div>
          <div class="mb-3">
            <label class="form-label">Ganti Gambar (opsional)</label>
            <input type="file" name="content_image" class="form-control" accept=".jpg,.jpeg,.png">
            <div class="form-text">Format: JPG, JPEG, atau PNG</div>
          </div>
          <div class="row">
            <div class="col-md-6 mb-3">
              <label class="form-label">Teks Tombol Input Pengajuan</label>
              <input type="text" name="btn_submit_text" class="form-control" value="<%= content.btn_submit_text ? content.btn_submit_text.content_value : 'Input Pengajuan' %>">
            </div>
            <div class="col-md-6 mb-3">
              <label class="form-label">Teks Tombol Tracking</label>
              <input type="text" name="btn_tracking_text" class="form-control" value="<%= content.btn_tracking_text ? content.btn_tracking_text.content_value : 'Tracking Pengajuan' %>">
            </div>
          </div>
          <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Simpan</button>
        </form>
      </div>
    </div>
  </div>
</div>
<%- include('../../partials/footer') %>
