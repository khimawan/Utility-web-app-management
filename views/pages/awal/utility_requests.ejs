<%- include('../../partials/header') %>
  <%- include('../../partials/topnav') %>
  <div class="page-content">
    <div class="page-header d-flex justify-content-between align-items-center">
      <h4><i class="bi bi-headset me-2"></i>Utility Requests</h4>
      <div class="d-flex gap-2">
        <a href="/utility/tracking" class="btn btn-outline-primary btn-sm" target="_blank"><i class="bi bi-search me-1"></i>Tracking Publik</a>
      </div>
    </div>

    <ul class="nav nav-tabs mb-3" id="utilityTabs">
      <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tabOpen"><i class="bi bi-folder2-open me-1"></i>Open (<%= open.length %>)</button></li>
      <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabClosed"><i class="bi bi-check-circle me-1"></i>Closed (<%= closed.length %>)</button></li>
      <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabOOS"><i class="bi bi-exclamation-triangle me-1"></i>Diluar Scoope (<%= outOfScope.length %>)</button></li>
      <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabHold"><i class="bi bi-pause-circle me-1"></i>On Hold (<%= onHold.length %>)</button></li>
    </ul>

    <div class="tab-content">
      <!-- Open Tab -->
      <div class="tab-pane fade show active" id="tabOpen">
        <div class="card">
          <div class="card-body">
            <div class="table-responsive">
              <table class="table table-striped table-hover">
                <thead>
                  <tr><th>Tanggal</th><th>Nama</th><th>Jabatan</th><th>WhatsApp</th><th>Issue</th><th>Priority</th><th>Area</th><th>Gedung</th><th>Dokumentasi</th><th>Manpower</th><th>Progress</th><th>Catatan</th><th>Aksi</th></tr>
                </thead>
                <tbody>
                  <% open.forEach(function(r) { %>
                  <tr>
                    <td><%= r.created_at ? r.created_at.slice(0,10) : '-' %></td>
                    <td><strong><%= r.requester_name %></strong></td>
                    <td><%= r.position %></td>
                    <td><%= r.whatsapp %></td>
                    <td style="max-width:180px;"><%= r.issue %></td>
                    <td><span class="badge bg-<%= r.priority === 'High' ? 'danger' : r.priority === 'Low' ? 'success' : 'warning' %>"><%= r.priority %></span></td>
                    <td><%= r.work_area %></td>
                    <td><span class="badge bg-secondary"><%= r.building %></span></td>
                    <td>
                      <% if (r.photo_url) { %>
                        <% if (r.photo_url.match(/\.(mp4|webm|quicktime)$/i)) { %>
                          <video src="<%= r.photo_url %>" style="max-height:50px;max-width:80px;" controls></video>
                        <% } else { %>
                          <a href="<%= r.photo_url %>" target="_blank"><img src="<%= r.photo_url %>" style="max-height:50px;max-width:80px;" class="rounded"></a>
                        <% } %>
                      <% } else { %><span class="text-muted">-</span><% } %>
                    </td>
                    <td><%= r.member_names || '<span class="text-muted">-</span>' %></td>
                    <td>
                      <div class="progress" style="height:18px;width:80px;">
                        <div class="progress-bar bg-success" style="width:<%= r.repair_percentage %>%"><%= r.repair_percentage %>%</div>
                      </div>
                    </td>
                    <td style="max-width:120px;"><small><%= r.repair_notes || '-' %></small></td>
                    <td>
                      <button class="btn btn-sm btn-outline-primary me-1 edit-utility"
                        data-id="<%= r.id %>"
                        data-status="open"
                        data-notes="<%= r.repair_notes || '' %>"
                        data-percentage="<%= r.repair_percentage %>"
                        data-memberids="<%= r.member_names || '' %>"
                        data-photo="<%= r.photo_url || '' %>">
                        <i class="bi bi-pencil"></i>
                      </button>
                      <form method="POST" action="/awal/utility-requests/<%= r.id %>/delete" style="display:inline;" class="delete-btn-form">
                        <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                      </form>
                    </td>
                  </tr>
                  <% }); %>
                  <% if (open.length === 0) { %>
                  <tr><td colspan="13" class="text-center text-muted">Tidak ada pengajuan open</td></tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>

      <!-- Closed Tab -->
      <div class="tab-pane fade" id="tabClosed">
        <div class="card">
          <div class="card-body">
            <div class="table-responsive">
              <table class="table table-striped table-hover">
                <thead>
                  <tr><th>Tanggal</th><th>Nama</th><th>Jabatan</th><th>WhatsApp</th><th>Issue</th><th>Priority</th><th>Area</th><th>Gedung</th><th>Dokumentasi</th><th>Manpower</th><th>Progress</th><th>Catatan</th><th>Aksi</th></tr>
                </thead>
                <tbody>
                  <% closed.forEach(function(r) { %>
                  <tr>
                    <td><%= r.created_at ? r.created_at.slice(0,10) : '-' %></td>
                    <td><strong><%= r.requester_name %></strong></td>
                    <td><%= r.position %></td>
                    <td><%= r.whatsapp %></td>
                    <td style="max-width:180px;"><%= r.issue %></td>
                    <td><span class="badge bg-<%= r.priority === 'High' ? 'danger' : r.priority === 'Low' ? 'success' : 'warning' %>"><%= r.priority %></span></td>
                    <td><%= r.work_area %></td>
                    <td><span class="badge bg-secondary"><%= r.building %></span></td>
                    <td>
                      <% if (r.photo_url) { %>
                        <% if (r.photo_url.match(/\.(mp4|webm|quicktime)$/i)) { %>
                          <video src="<%= r.photo_url %>" style="max-height:50px;max-width:80px;" controls></video>
                        <% } else { %>
                          <a href="<%= r.photo_url %>" target="_blank"><img src="<%= r.photo_url %>" style="max-height:50px;max-width:80px;" class="rounded"></a>
                        <% } %>
                      <% } else { %><span class="text-muted">-</span><% } %>
                    </td>
                    <td><%= r.member_names || '<span class="text-muted">-</span>' %></td>
                    <td>
                      <div class="progress" style="height:18px;width:80px;">
                        <div class="progress-bar bg-success" style="width:100%">100%</div>
                      </div>
                    </td>
                    <td style="max-width:120px;"><small><%= r.repair_notes || '-' %></small></td>
                    <td>
                      <button class="btn btn-sm btn-outline-primary me-1 edit-utility"
                        data-id="<%= r.id %>"
                        data-status="closed"
                        data-notes="<%= r.repair_notes || '' %>"
                        data-percentage="100"
                        data-memberids="<%= r.member_names || '' %>"
                        data-photo="<%= r.photo_url || '' %>">
                        <i class="bi bi-pencil"></i>
                      </button>
                    </td>
                  </tr>
                  <% }); %>
                  <% if (closed.length === 0) { %>
                  <tr><td colspan="13" class="text-center text-muted">Tidak ada pengajuan closed</td></tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>

      <!-- Diluar Scoope Tab -->
      <div class="tab-pane fade" id="tabOOS">
        <div class="card">
          <div class="card-body">
            <div class="table-responsive">
              <table class="table table-striped table-hover">
                <thead>
                  <tr><th>Tanggal</th><th>Nama</th><th>Jabatan</th><th>WhatsApp</th><th>Issue</th><th>Priority</th><th>Area</th><th>Gedung</th><th>Dokumentasi</th><th>Manpower</th><th>Progress</th><th>Catatan</th><th>Aksi</th></tr>
                </thead>
                <tbody>
                  <% outOfScope.forEach(function(r) { %>
                  <tr>
                    <td><%= r.created_at ? r.created_at.slice(0,10) : '-' %></td>
                    <td><strong><%= r.requester_name %></strong></td>
                    <td><%= r.position %></td>
                    <td><%= r.whatsapp %></td>
                    <td style="max-width:180px;"><%= r.issue %></td>
                    <td><span class="badge bg-<%= r.priority === 'High' ? 'danger' : r.priority === 'Low' ? 'success' : 'warning' %>"><%= r.priority %></span></td>
                    <td><%= r.work_area %></td>
                    <td><span class="badge bg-secondary"><%= r.building %></span></td>
                    <td>
                      <% if (r.photo_url) { %>
                        <% if (r.photo_url.match(/\.(mp4|webm|quicktime)$/i)) { %>
                          <video src="<%= r.photo_url %>" style="max-height:50px;max-width:80px;" controls></video>
                        <% } else { %>
                          <a href="<%= r.photo_url %>" target="_blank"><img src="<%= r.photo_url %>" style="max-height:50px;max-width:80px;" class="rounded"></a>
                        <% } %>
                      <% } else { %><span class="text-muted">-</span><% } %>
                    </td>
                    <td><%= r.member_names || '<span class="text-muted">-</span>' %></td>
                    <td>
                      <div class="progress" style="height:18px;width:80px;">
                        <div class="progress-bar bg-warning" style="width:<%= r.repair_percentage %>%"><%= r.repair_percentage %>%</div>
                      </div>
                    </td>
                    <td style="max-width:120px;"><small><%= r.repair_notes || '-' %></small></td>
                    <td>
                      <button class="btn btn-sm btn-outline-primary me-1 edit-utility"
                        data-id="<%= r.id %>"
                        data-status="diluar_scoope"
                        data-notes="<%= r.repair_notes || '' %>"
                        data-percentage="<%= r.repair_percentage %>"
                        data-memberids="<%= r.member_names || '' %>"
                        data-photo="<%= r.photo_url || '' %>">
                        <i class="bi bi-pencil"></i>
                      </button>
                      <form method="POST" action="/awal/utility-requests/<%= r.id %>/delete" style="display:inline;" class="delete-btn-form">
                        <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                      </form>
                    </td>
                  </tr>
                  <% }); %>
                  <% if (outOfScope.length === 0) { %>
                  <tr><td colspan="13" class="text-center text-muted">Tidak ada pengajuan diluar scoope</td></tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>

      <!-- On Hold Tab -->
      <div class="tab-pane fade" id="tabHold">
        <div class="card">
          <div class="card-body">
            <div class="table-responsive">
              <table class="table table-striped table-hover">
                <thead>
                  <tr><th>Tanggal</th><th>Nama</th><th>Jabatan</th><th>WhatsApp</th><th>Issue</th><th>Priority</th><th>Area</th><th>Gedung</th><th>Dokumentasi</th><th>Manpower</th><th>Progress</th><th>Catatan</th><th>Aksi</th></tr>
                </thead>
                <tbody>
                  <% onHold.forEach(function(r) { %>
                  <tr>
                    <td><%= r.created_at ? r.created_at.slice(0,10) : '-' %></td>
                    <td><strong><%= r.requester_name %></strong></td>
                    <td><%= r.position %></td>
                    <td><%= r.whatsapp %></td>
                    <td style="max-width:180px;"><%= r.issue %></td>
                    <td><span class="badge bg-<%= r.priority === 'High' ? 'danger' : r.priority === 'Low' ? 'success' : 'warning' %>"><%= r.priority %></span></td>
                    <td><%= r.work_area %></td>
                    <td><span class="badge bg-secondary"><%= r.building %></span></td>
                    <td>
                      <% if (r.photo_url) { %>
                        <% if (r.photo_url.match(/\.(mp4|webm|quicktime)$/i)) { %>
                          <video src="<%= r.photo_url %>" style="max-height:50px;max-width:80px;" controls></video>
                        <% } else { %>
                          <a href="<%= r.photo_url %>" target="_blank"><img src="<%= r.photo_url %>" style="max-height:50px;max-width:80px;" class="rounded"></a>
                        <% } %>
                      <% } else { %><span class="text-muted">-</span><% } %>
                    </td>
                    <td><%= r.member_names || '<span class="text-muted">-</span>' %></td>
                    <td>
                      <div class="progress" style="height:18px;width:80px;">
                        <div class="progress-bar bg-secondary" style="width:<%= r.repair_percentage %>%"><%= r.repair_percentage %>%</div>
                      </div>
                    </td>
                    <td style="max-width:120px;"><small><%= r.repair_notes || '-' %></small></td>
                    <td>
                      <button class="btn btn-sm btn-outline-primary me-1 edit-utility"
                        data-id="<%= r.id %>"
                        data-status="on_hold"
                        data-notes="<%= r.repair_notes || '' %>"
                        data-percentage="<%= r.repair_percentage %>"
                        data-memberids="<%= r.member_names || '' %>"
                        data-photo="<%= r.photo_url || '' %>">
                        <i class="bi bi-pencil"></i>
                      </button>
                      <form method="POST" action="/awal/utility-requests/<%= r.id %>/delete" style="display:inline;" class="delete-btn-form">
                        <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                      </form>
                    </td>
                  </tr>
                  <% }); %>
                  <% if (onHold.length === 0) { %>
                  <tr><td colspan="13" class="text-center text-muted">Tidak ada pengajuan on hold</td></tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Edit Modal -->
    <div class="modal fade" id="editUtilityModal" tabindex="-1">
      <div class="modal-dialog">
        <div class="modal-content">
          <form method="POST" id="editUtilityForm" enctype="multipart/form-data">
            <div class="modal-header">
              <h5 class="modal-title">Edit Utility Request</h5>
              <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
              <div class="mb-3">
                <label class="form-label">Status</label>
                <select name="status" class="form-select" id="edit_utility_status">
                  <option value="open">Open</option>
                  <option value="closed">Closed</option>
                  <option value="diluar_scoope">Diluar Scoope</option>
                  <option value="on_hold">On Hold</option>
                </select>
              </div>
              <div class="mb-3">
                <label class="form-label">Persentase Perbaikan (%)</label>
                <input type="number" name="repair_percentage" class="form-control" min="0" max="100" id="edit_utility_percentage">
              </div>
              <div class="mb-3">
                <label class="form-label">Catatan Perbaikan</label>
                <textarea name="repair_notes" class="form-control" rows="2" id="edit_utility_notes"></textarea>
              </div>
              <div class="mb-3">
                <label class="form-label">Manpower (Member)</label>
                <div class="border rounded p-3" style="max-height: 200px; overflow-y: auto;">
                  <% members.forEach(function(m) { %>
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="member_ids" value="<%= m.id %>" id="edit_utility_member_<%= m.id %>">
                    <label class="form-check-label" for="edit_utility_member_<%= m.id %>">
                      <%= m.name %> <span class="badge bg-secondary ms-1"><%= m.job || 'N/A' %></span>
                    </label>
                  </div>
                  <% }); %>
                </div>
              </div>
              <div class="mb-3">
                <label class="form-label">Dokumentasi Saat Ini</label>
                <div id="edit_utility_photo_preview" class="mb-2"></div>
                <input type="hidden" name="delete_photo" id="edit_utility_delete_photo" value="0">
              </div>
              <div class="mb-3">
                <label class="form-label">Ganti Dokumentasi (Foto/Video)</label>
                <input type="file" name="photo" class="form-control" accept=".jpg,.jpeg,.png,.mp4,.webm">
                <div class="form-text">Format: JPG, JPEG, PNG, MP4, atau WebM. Maks 50MB.</div>
              </div>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
              <button type="submit" class="btn btn-primary">Update</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
document.querySelectorAll('.edit-utility').forEach(function(btn) {
  btn.addEventListener('click', function() {
    document.getElementById('editUtilityForm').action = '/awal/utility-requests/' + this.dataset.id;
    document.getElementById('edit_utility_status').value = this.dataset.status;
    document.getElementById('edit_utility_notes').value = this.dataset.notes;
    document.getElementById('edit_utility_percentage').value = this.dataset.percentage;
    document.getElementById('edit_utility_delete_photo').value = '0';

    var photoUrl = this.dataset.photo;
    var preview = document.getElementById('edit_utility_photo_preview');
    if (photoUrl) {
      if (photoUrl.match(/\.(mp4|webm|quicktime)$/i)) {
        preview.innerHTML = '<div class="d-flex align-items-center gap-2"><video src="' + photoUrl + '" style="max-height:80px;max-width:120px;" controls></video><button type="button" class="btn btn-sm btn-outline-danger" onclick="document.getElementById(\'edit_utility_photo_preview\').innerHTML=\'<span class=text-muted>Tidak ada</span>\';document.getElementById(\'edit_utility_delete_photo\').value=\'1\';"><i class="bi bi-trash"></i> Hapus</button></div>';
      } else {
        preview.innerHTML = '<div class="d-flex align-items-center gap-2"><a href="' + photoUrl + '" target="_blank"><img src="' + photoUrl + '" style="max-height:80px;max-width:120px;" class="rounded"></a><button type="button" class="btn btn-sm btn-outline-danger" onclick="document.getElementById(\'edit_utility_photo_preview\').innerHTML=\'<span class=text-muted>Tidak ada</span>\';document.getElementById(\'edit_utility_delete_photo\').value=\'1\';"><i class="bi bi-trash"></i> Hapus</button></div>';
      }
    } else {
      preview.innerHTML = '<span class="text-muted">Tidak ada dokumentasi</span>';
    }

    document.querySelectorAll('#editUtilityModal input[name="member_ids"]').forEach(function(cb) {
      cb.checked = false;
    });

    var memberNames = this.dataset.memberids;
    if (memberNames) {
      var names = memberNames.split(', ');
      names.forEach(function(name) {
        document.querySelectorAll('#editUtilityModal .form-check-label').forEach(function(label) {
          if (label.textContent.trim().startsWith(name.trim())) {
            label.previousElementSibling.checked = true;
          }
        });
      });
    }

    new bootstrap.Modal(document.getElementById('editUtilityModal')).show();
  });
});
</script>
<%- include('../../partials/footer') %>
