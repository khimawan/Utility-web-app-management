<%- include('../../partials/header') %>
  <%- include('../../partials/topnav') %>
  <div class="page-content">
    <div class="page-header d-flex justify-content-between align-items-center">
      <h4><i class="bi bi-exclamation-triangle me-2"></i>List Warning Mesin</h4>
      <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addWarningModal">
        <i class="bi bi-plus-circle me-1"></i>Tambah Warning
      </button>
    </div>

    <div class="card">
      <div class="card-body">
            <div class="delete-selected-bar">
              <button class="btn btn-sm btn-outline-danger" onclick="deleteSelected('/awal/warnings/delete-multiple')"><i class="bi bi-trash me-1"></i>Hapus Terpilih</button>
            </div>
        <div class="table-responsive scrollable-table">
          <table class="table table-striped table-hover">
            <thead>
              <tr>
                <th><input type="checkbox" class="select-all-checkbox"></th>
                <th>Tanggal</th>
                <th>Mesin</th>
                <th>Deskripsi</th>
                <th>Member</th>
                <th>Catatan</th>
                <th>Progres</th>
                <th>Dokumentasi</th>
                <th>Aksi</th>
              </tr>
            </thead>
            <tbody>
              <% warnings.forEach(function(w) { %>
              <tr>
                <td><input type="checkbox" class="row-checkbox" value="<%= w.id %>"></td>
                <td><%= w.warning_date %></td>
                <td><span class="badge bg-warning text-dark"><%= w.machine_name %></span></td>
                <td><%= w.description %></td>
                <td><%= w.member_names || '-' %></td>
                <td><%= w.repair_notes || '-' %></td>
                <td>
                  <div class="progress" style="height: 20px; width: 100px;">
                    <div class="progress-bar bg-success" style="width: <%= w.repair_percentage %>%"><%= w.repair_percentage %>%</div>
                  </div>
                </td>
                <td>
                  <% if (w.photo_url) { %>
                    <% if (w.photo_url.match(/\.(mp4|webm|quicktime)$/i)) { %>
                      <video src="<%= w.photo_url %>" style="max-height:50px;max-width:80px;" controls></video>
                    <% } else { %>
                      <a href="<%= w.photo_url %>" target="_blank"><img src="<%= w.photo_url %>" style="max-height:50px;max-width:80px;" class="rounded"></a>
                    <% } %>
                  <% } else { %>
                    <span class="text-muted">-</span>
                  <% } %>
                </td>
                <td>
                  <button class="btn btn-sm btn-outline-primary me-1 edit-warning"
                    data-id="<%= w.id %>"
                    data-date="<%= w.warning_date %>"
                    data-machine="<%= w.machine_name %>"
                    data-desc="<%= w.description %>"
                    data-notes="<%= w.repair_notes || '' %>"
                    data-percentage="<%= w.repair_percentage %>"
                    data-memberids="<%= w.member_names || '' %>"
                    data-photo="<%= w.photo_url || '' %>">
                    <i class="bi bi-pencil"></i>
                  </button>
                  <form method="POST" action="/awal/warnings/<%= w.id %>/delete" style="display:inline;" class="delete-btn-form">
                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                  </form>
                </td>
              </tr>
              <% }); %>
              <% if (warnings.length === 0) { %>
              <tr><td colspan="9" class="text-center text-muted">Belum ada data warning</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <div class="modal fade" id="addWarningModal" tabindex="-1">
      <div class="modal-dialog">
        <div class="modal-content">
          <form method="POST" action="/awal/warnings" enctype="multipart/form-data">
            <div class="modal-header">
              <h5 class="modal-title">Tambah Warning</h5>
              <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
              <div class="mb-3">
                <label class="form-label">Tanggal</label>
                <input type="date" name="warning_date" class="form-control" required>
              </div>
              <div class="mb-3">
                <label class="form-label">Nama Mesin</label>
                <select name="machine_name" class="form-select" required>
                  <option value="wtp">WTP</option>
                  <option value="boiler">Boiler</option>
                  <option value="n2_generator">N2 Generator</option>
                  <option value="kompressor01">Kompressor 01</option>
                  <option value="kompressor02">Kompressor 02</option>
                  <option value="kompressor03">Kompressor 03</option>
                  <option value="kompressor04">Kompressor 04</option>
                </select>
              </div>
              <div class="mb-3">
                <label class="form-label">Deskripsi Warning</label>
                <textarea name="description" class="form-control" rows="3" required></textarea>
              </div>
              <div class="mb-3">
                <label class="form-label">Pilih Member</label>
                <div class="border rounded p-3" style="max-height: 200px; overflow-y: auto;">
                  <% members.forEach(function(m) { %>
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="member_ids" value="<%= m.id %>" id="add_member_<%= m.id %>">
                    <label class="form-check-label" for="add_member_<%= m.id %>">
                      <%= m.name %> <span class="badge bg-secondary ms-1"><%= m.job || 'N/A' %></span>
                    </label>
                  </div>
                  <% }); %>
                </div>
              </div>
              <div class="mb-3">
                <label class="form-label">Catatan Perbaikan</label>
                <textarea name="repair_notes" class="form-control" rows="2"></textarea>
              </div>
              <div class="mb-3">
                <label class="form-label">Persentase Perbaikan (%)</label>
                <input type="number" name="repair_percentage" class="form-control" min="0" max="100" value="0">
              </div>
              <div class="mb-3">
                <label class="form-label">Dokumentasi (Foto/Video)</label>
                <input type="file" name="photo" class="form-control" accept=".jpg,.jpeg,.png,.mp4,.webm">
                <div class="form-text">Format: JPG, JPEG, PNG, MP4, atau WebM. Maks 50MB.</div>
              </div>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
              <button type="submit" class="btn btn-primary">Simpan</button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <div class="modal fade" id="editWarningModal" tabindex="-1">
      <div class="modal-dialog">
        <div class="modal-content">
          <form method="POST" id="editWarningForm" enctype="multipart/form-data">
            <div class="modal-header">
              <h5 class="modal-title">Edit Warning</h5>
              <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
              <div class="mb-3">
                <label class="form-label">Tanggal</label>
                <input type="date" name="warning_date" class="form-control" id="edit_warning_date" required>
              </div>
              <div class="mb-3">
                <label class="form-label">Nama Mesin</label>
                <select name="machine_name" class="form-select" id="edit_warning_machine" required>
                  <option value="wtp">WTP</option>
                  <option value="boiler">Boiler</option>
                  <option value="n2_generator">N2 Generator</option>
                  <option value="kompressor01">Kompressor 01</option>
                  <option value="kompressor02">Kompressor 02</option>
                  <option value="kompressor03">Kompressor 03</option>
                  <option value="kompressor04">Kompressor 04</option>
                </select>
              </div>
              <div class="mb-3">
                <label class="form-label">Deskripsi Warning</label>
                <textarea name="description" class="form-control" rows="3" id="edit_warning_desc" required></textarea>
              </div>
              <div class="mb-3">
                <label class="form-label">Pilih Member</label>
                <div class="border rounded p-3" style="max-height: 200px; overflow-y: auto;">
                  <% members.forEach(function(m) { %>
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="member_ids" value="<%= m.id %>" id="edit_wmember_<%= m.id %>">
                    <label class="form-check-label" for="edit_wmember_<%= m.id %>">
                      <%= m.name %> <span class="badge bg-secondary ms-1"><%= m.job || 'N/A' %></span>
                    </label>
                  </div>
                  <% }); %>
                </div>
              </div>
              <div class="mb-3">
                <label class="form-label">Catatan Perbaikan</label>
                <textarea name="repair_notes" class="form-control" rows="2" id="edit_warning_notes"></textarea>
              </div>
              <div class="mb-3">
                <label class="form-label">Persentase Perbaikan (%)</label>
                <input type="number" name="repair_percentage" class="form-control" min="0" max="100" id="edit_warning_percentage">
              </div>
              <div class="mb-3">
                <label class="form-label">Dokumentasi Saat Ini</label>
                <div id="edit_warning_photo_preview" class="mb-2"></div>
                <input type="hidden" name="delete_photo" id="edit_warning_delete_photo" value="0">
              </div>
              <div class="mb-3">
                <label class="form-label">Ganti Dokumentasi (Foto/Video)</label>
                <input type="file" name="photo" class="form-control" accept=".jpg,.jpeg,.png,.mp4,.webm">
                <div class="form-text">Format: JPG, JPEG, PNG, MP4, atau WebM. Maks 50MB.</div>
              </div>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
              <button type="submit" class="btn btn-primary">Update</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
document.querySelectorAll('.edit-warning').forEach(function(btn) {
  btn.addEventListener('click', function() {
    document.getElementById('editWarningForm').action = '/awal/warnings/' + this.dataset.id;
    document.getElementById('edit_warning_date').value = this.dataset.date;
    document.getElementById('edit_warning_machine').value = this.dataset.machine;
    document.getElementById('edit_warning_desc').value = this.dataset.desc;
    document.getElementById('edit_warning_notes').value = this.dataset.notes;
    document.getElementById('edit_warning_percentage').value = this.dataset.percentage;
    document.getElementById('edit_warning_delete_photo').value = '0';

    var photoUrl = this.dataset.photo;
    var preview = document.getElementById('edit_warning_photo_preview');
    if (photoUrl) {
      if (photoUrl.match(/\.(mp4|webm|quicktime)$/i)) {
        preview.innerHTML = '<div class="d-flex align-items-center gap-2"><video src="' + photoUrl + '" style="max-height:80px;max-width:120px;" controls></video><button type="button" class="btn btn-sm btn-outline-danger" onclick="document.getElementById(\'edit_warning_photo_preview\').innerHTML=\'<span class=text-muted>\Tidak ada<\/span>\';document.getElementById(\'edit_warning_delete_photo\').value=\'1\';"><i class="bi bi-trash"></i> Hapus</button></div>';
      } else {
        preview.innerHTML = '<div class="d-flex align-items-center gap-2"><a href="' + photoUrl + '" target="_blank"><img src="' + photoUrl + '" style="max-height:80px;max-width:120px;" class="rounded"></a><button type="button" class="btn btn-sm btn-outline-danger" onclick="document.getElementById(\'edit_warning_photo_preview\').innerHTML=\'<span class=text-muted>\Tidak ada<\/span>\';document.getElementById(\'edit_warning_delete_photo\').value=\'1\';"><i class="bi bi-trash"></i> Hapus</button></div>';
      }
    } else {
      preview.innerHTML = '<span class="text-muted">Tidak ada dokumentasi</span>';
    }

    document.querySelectorAll('#editWarningModal input[name="member_ids"]').forEach(function(cb) {
      cb.checked = false;
    });

    var memberNames = this.dataset.memberids;
    if (memberNames) {
      var names = memberNames.split(', ');
      names.forEach(function(name) {
        document.querySelectorAll('#editWarningModal .form-check-label').forEach(function(label) {
          if (label.textContent.trim().startsWith(name.trim())) {
            label.previousElementSibling.checked = true;
          }
        });
      });
    }

    new bootstrap.Modal(document.getElementById('editWarningModal')).show();
  });
});
</script>
<%- include('../../partials/footer') %>
