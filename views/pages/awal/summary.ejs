<%- include('../../partials/header') %>
  <%- include('../../partials/topnav') %>
  <div class="page-content">
    <div class="page-header d-flex justify-content-between align-items-center">
      <h4><i class="bi bi-graph-up me-2"></i>Summary Data</h4>
      <div class="d-flex gap-2">
        <select id="periodSelect" class="form-select form-select-sm" style="width: 150px;">
          <option value="week">1 Minggu</option>
          <option value="month">1 Bulan</option>
          <option value="year">1 Tahun</option>
        </select>
      </div>
    </div>

    <div class="row">
      <div class="col-12 mb-4">
        <div class="card border-success">
          <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><i class="bi bi-upload me-2"></i>Import Data CSV</h5>
          </div>
          <div class="card-body">
            <div class="row align-items-end g-3">
              <div class="col-md-3">
                <label class="form-label">Pilih Kategori</label>
                <select id="importCategory" class="form-select">
                  <% categories.forEach(function(cat) { %>
                    <option value="<%= cat %>"><%= cat.replace(/_/g, ' ').toUpperCase() %></option>
                  <% }); %>
                </select>
              </div>
              <div class="col-md-3">
                <label class="form-label">File CSV</label>
                <input type="file" id="importFile" class="form-control" accept=".csv">
              </div>
              <div class="col-md-2">
                <button class="btn btn-outline-secondary w-100" onclick="downloadTemplate()">
                  <i class="bi bi-file-earmark-arrow-down me-1"></i> Download Template
                </button>
              </div>
              <div class="col-md-2">
                <button class="btn btn-success w-100" onclick="importCSV()">
                  <i class="bi bi-upload me-1"></i> Import
                </button>
              </div>
              <div class="col-md-2">
                <div id="importStatus" class="text-muted small"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <% categories.forEach(function(cat) { %>
      <div class="col-12 mb-4">
        <div class="card">
          <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="text-capitalize"><%= cat.replace(/_/g, ' ') %></h5>
            <div class="d-flex gap-2">
              <button class="btn btn-sm btn-outline-success" onclick="downloadCSV('<%= cat %>')">
                <i class="bi bi-download"></i> CSV
              </button>
              <button class="btn btn-sm btn-outline-primary" onclick="loadCategoryData('<%= cat %>')">
                <i class="bi bi-arrow-clockwise"></i> Refresh
              </button>
            </div>
          </div>
          <div class="card-body">
            <div class="row">
              <div class="col-md-8">
                <div class="chart-container">
                  <canvas id="chart_<%= cat %>"></canvas>
                </div>
              </div>
              <div class="col-md-4">
                <div class="chart-container">
                  <canvas id="pie_<%= cat %>"></canvas>
                </div>
              </div>
            </div>
            <div class="table-responsive mt-3">
              <table class="table table-sm table-striped" id="table_<%= cat %>">
                <thead>
                  <tr>
                    <th>Tanggal</th>
                    <th>Shift</th>
                    <th>Parameter</th>
                    <th>Nilai</th>
                    <th>Satuan</th>
                  </tr>
                </thead>
                <tbody></tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
      <% }); %>
    </div>
  </div>
</div>

<script>
const categories = <%- JSON.stringify(categories) %>;
const templates = <%- JSON.stringify(templates) %>;
const categoryData = {};

categories.forEach(function(cat) {
  loadCategoryData(cat);
});

function loadCategoryData(category) {
  const period = document.getElementById('periodSelect').value;
  fetch('/awal/api/summary-data?category=' + category + '&period=' + period)
    .then(r => r.json())
    .then(data => {
      categoryData[category] = data;
      updateChart(category, data);
      updateTable(category, data);
    })
    .catch(err => console.error(err));
}

function downloadCSV(category) {
  const data = categoryData[category];
  if (!data || data.length === 0) {
    alert('Tidak ada data untuk di-download');
    return;
  }

  const header = ['Tanggal', 'Shift', 'Parameter', 'Nilai', 'Satuan'];
  const rows = data.map(function(row) {
    return [
      row.entry_date,
      row.shift,
      '"' + (row.parameter_name || '').replace(/"/g, '""') + '"',
      '"' + (row.parameter_value || '').replace(/"/g, '""') + '"',
      '"' + (row.unit || '').replace(/"/g, '""') + '"'
    ].join(',');
  });

  const csv = '\uFEFF' + header.join(',') + '\n' + rows.join('\n');
  const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
  const url = URL.createObjectURL(blob);
  const link = document.createElement('a');
  link.setAttribute('href', url);
  link.setAttribute('download', 'checklist_' + category + '_' + new Date().toISOString().slice(0, 10) + '.csv');
  document.body.appendChild(link);
  link.click();
  document.body.removeChild(link);
  URL.revokeObjectURL(url);
}

function updateChart(category, data) {
  const numericParams = {};
  const textParams = {};

  data.forEach(function(row) {
    if (row.parameter_type === 'number') {
      if (!numericParams[row.parameter_name]) numericParams[row.parameter_name] = [];
      numericParams[row.parameter_name].push({ date: row.entry_date, value: parseFloat(row.parameter_value) || 0 });
    } else {
      if (!textParams[row.parameter_name]) textParams[row.parameter_name] = {};
      const val = row.parameter_value || 'N/A';
      textParams[row.parameter_name][val] = (textParams[row.parameter_name][val] || 0) + 1;
    }
  });

  const colors = ['#1e3c72', '#2a5298', '#e74c3c', '#2ecc71', '#f39c12', '#9b59b6'];
  const datasets = [];
  let labels = [...new Set(data.map(r => r.entry_date))].sort();

  Object.keys(numericParams).forEach(function(param, i) {
    const values = {};
    numericParams[param].forEach(function(v) { values[v.date] = v.value; });
    datasets.push({
      label: param,
      data: labels.map(function(l) { return values[l] || 0; }),
      borderColor: colors[i % colors.length],
      tension: 0.3,
      fill: false
    });
  });

  const canvasId = 'chart_' + category;
  const existing = Chart.getChart(canvasId);
  if (existing) existing.destroy();

  if (datasets.length > 0) {
    createLineChart(canvasId, labels, datasets);
  }

  const pieCanvasId = 'pie_' + category;
  const existingPie = Chart.getChart(pieCanvasId);
  if (existingPie) existingPie.destroy();

  const pieLabels = [];
  const pieData = [];
  Object.keys(textParams).forEach(function(param) {
    Object.keys(textParams[param]).forEach(function(val) {
      pieLabels.push(param + ': ' + val);
      pieData.push(textParams[param][val]);
    });
  });

  if (pieLabels.length > 0) {
    createPieChart(pieCanvasId, pieLabels, pieData);
  }
}

function updateTable(category, data) {
  const tbody = document.querySelector('#table_' + category + ' tbody');
  tbody.innerHTML = '';
  data.forEach(function(row) {
    const tr = document.createElement('tr');
    tr.innerHTML = '<td>' + row.entry_date + '</td><td>' + row.shift + '</td><td>' + row.parameter_name + '</td><td>' + row.parameter_value + '</td><td>' + (row.unit || '') + '</td>';
    tbody.appendChild(tr);
  });
}

document.getElementById('periodSelect').addEventListener('change', function() {
  categories.forEach(function(cat) { loadCategoryData(cat); });
});

function downloadTemplate() {
  const category = document.getElementById('importCategory').value;
  window.location.href = '/awal/api/template-csv/' + category;
}

function importCSV() {
  const category = document.getElementById('importCategory').value;
  const fileInput = document.getElementById('importFile');
  const status = document.getElementById('importStatus');

  if (!fileInput.files.length) {
    alert('Pilih file CSV terlebih dahulu');
    return;
  }

  const file = fileInput.files[0];
  const reader = new FileReader();
  reader.onload = function(e) {
    const csvData = e.target.result;
    status.innerHTML = '<i class="bi bi-hourglass-split"></i> Mengimport...';
    status.className = 'text-primary small';

    fetch('/awal/api/import-csv', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ category: category, csv_data: csvData })
    })
    .then(function(r) { return r.json(); })
    .then(function(result) {
      if (result.success) {
        let msg = 'Berhasil import ' + result.imported + ' data';
        if (result.errors.length > 0) {
          msg += '\n\n' + result.errors.length + ' error:\n' + result.errors.slice(0, 5).join('\n');
        }
        status.innerHTML = '<i class="bi bi-check-circle text-success"></i> ' + result.imported + ' data berhasil diimport';
        status.className = 'text-success small';
        fileInput.value = '';
        loadCategoryData(category);
      } else {
        status.innerHTML = '<i class="bi bi-exclamation-circle text-danger"></i> ' + result.error;
        status.className = 'text-danger small';
      }
    })
    .catch(function(err) {
      status.innerHTML = '<i class="bi bi-exclamation-circle text-danger"></i> Gagal import';
      status.className = 'text-danger small';
      console.error(err);
    });
  };
  reader.readAsText(file);
}
</script>
<%- include('../../partials/footer') %>
