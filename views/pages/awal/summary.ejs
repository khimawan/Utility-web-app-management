<%- include('../../partials/header') %>
  <%- include('../../partials/topnav') %>
  <div class="page-content">
    <div class="page-header d-flex justify-content-between align-items-center">
      <h4><i class="bi bi-graph-up me-2"></i>Summary Data</h4>
      <div class="d-flex gap-2">
        <form method="GET" action="/awal/summary" class="d-flex gap-2">
          <input type="date" name="date" class="form-control form-control-sm" value="<%= selectedDate %>">
          <button type="submit" class="btn btn-sm btn-primary"><i class="bi bi-search"></i></button>
        </form>
        <select id="periodSelect" class="form-select form-select-sm" style="width: 150px;">
          <option value="week">1 Minggu</option>
          <option value="month">1 Bulan</option>
          <option value="year">1 Tahun</option>
        </select>
      </div>
    </div>

    <div class="row">
      <div class="col-12 mb-4">
        <div class="card border-success">
          <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><i class="bi bi-upload me-2"></i>Import Data CSV</h5>
          </div>
          <div class="card-body">
            <div class="row align-items-end g-3">
              <div class="col-md-3">
                <label class="form-label">Pilih Kategori</label>
                <select id="importCategory" class="form-select">
                  <% categories.forEach(function(cat) { %>
                    <option value="<%= cat %>"><%= cat.replace(/_/g, ' ').toUpperCase() %></option>
                  <% }); %>
                </select>
              </div>
              <div class="col-md-3">
                <label class="form-label">File CSV</label>
                <input type="file" id="importFile" class="form-control" accept=".csv">
              </div>
              <div class="col-md-2">
                <button class="btn btn-outline-secondary w-100" onclick="downloadTemplate()">
                  <i class="bi bi-file-earmark-arrow-down me-1"></i> Download Template
                </button>
              </div>
              <div class="col-md-2">
                <button class="btn btn-success w-100" onclick="importCSV()">
                  <i class="bi bi-upload me-1"></i> Import
                </button>
              </div>
              <div class="col-md-2">
                <div id="importStatus" class="text-muted small"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <% categories.forEach(function(cat) { %>
      <div class="col-12 mb-4">
        <div class="card">
          <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="text-capitalize"><%= cat.replace(/_/g, ' ') %></h5>
            <div class="d-flex gap-2">
              <button class="btn btn-sm btn-outline-success" onclick="downloadCSV('<%= cat %>')">
                <i class="bi bi-download"></i> CSV
              </button>
              <button class="btn btn-sm btn-outline-primary" onclick="loadCategoryData('<%= cat %>')">
                <i class="bi bi-arrow-clockwise"></i> Refresh
              </button>
            </div>
          </div>
          <div class="card-body">
            <div class="row">
              <div class="col-md-8">
                <div class="chart-container">
                  <canvas id="chart_<%= cat %>"></canvas>
                </div>
              </div>
              <div class="col-md-4">
                <div class="chart-container">
                  <canvas id="pie_<%= cat %>"></canvas>
                </div>
              </div>
            </div>
            <div class="table-responsive mt-3">
              <table class="table table-sm table-striped" id="table_<%= cat %>">
                <thead>
                  <tr>
                    <th>Tanggal</th>
                    <th>Shift</th>
                    <th>Parameter</th>
                    <th>Nilai</th>
                    <th>Satuan</th>
                  </tr>
                </thead>
                <tbody></tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
      <% }); %>

