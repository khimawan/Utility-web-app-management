<%- include('../../partials/header') %>
  <%- include('../../partials/topnav') %>
  <div class="page-content">
    <div class="page-header">
      <h4><i class="bi bi-people me-2"></i>Member & Jadwal</h4>
    </div>

    <div class="row">
      <div class="col-md-8">
        <div class="card">
          <div class="card-header d-flex justify-content-between align-items-center">
            <h5>Jadwal Shift</h5>
            <div class="d-flex gap-2">
              <form method="GET" action="/awal/member" class="d-flex gap-2">
                <input type="date" name="date" class="form-control form-control-sm" value="<%= selectedDate %>">
                <button type="submit" class="btn btn-sm btn-primary"><i class="bi bi-search"></i></button>
              </form>
            </div>
          </div>
          <div class="card-body">
            <table class="table table-striped">
              <thead>
                <tr>
                  <th>Shift</th>
                  <th>Nama Member</th>
                  <th>Job</th>
                  <th>Aksi</th>
                </tr>
              </thead>
              <tbody>
                <% ['1','2','3'].forEach(function(shift) { %>
                  <% schedules.filter(function(s) { return s.shift === shift; }).forEach(function(s) { %>
                  <tr>
                    <td><span class="badge bg-primary">Shift <%= s.shift %></span></td>
                    <td><%= s.member_name || '-' %></td>
                    <td><span class="badge bg-info"><%= s.job %></span></td>
                    <td>
                      <form method="POST" action="/awal/member/schedule/<%= s.id %>/delete" style="display:inline;" class="delete-btn-form">
                        <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                      </form>
                    </td>
                  </tr>
                  <% }); %>
                <% }); %>
                <% if (schedules.length === 0) { %>
                <tr><td colspan="4" class="text-center text-muted">Tidak ada jadwal untuk tanggal ini</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <div class="col-md-4">
        <div class="card">
          <div class="card-header">
            <h5>Tambah Jadwal</h5>
          </div>
          <div class="card-body">
            <form method="POST" action="/awal/member/schedule">
              <input type="hidden" name="schedule_date" value="<%= selectedDate %>">
              <div class="mb-3">
                <label class="form-label">Shift</label>
                <select name="shift" class="form-select" required>
                  <option value="1">Shift 1</option>
                  <option value="2">Shift 2</option>
                  <option value="3">Shift 3</option>
                </select>
              </div>
              <div class="mb-3">
                <label class="form-label">Member</label>
                <select name="member_id" class="form-select" required>
                  <% members.forEach(function(m) { %>
                  <option value="<%= m.id %>"><%= m.name %></option>
                  <% }); %>
                </select>
              </div>
              <div class="mb-3">
                <label class="form-label">Job</label>
                <select name="job" class="form-select" required>
                  <option value="operator_wtp">Operator WTP</option>
                  <option value="operator_n2">Operator N2</option>
                  <option value="facility">Facility</option>
                </select>
              </div>
              <button type="submit" class="btn btn-primary w-100"><i class="bi bi-plus-circle me-1"></i>Tambah</button>
            </form>
          </div>
        </div>

        <div class="card">
          <div class="card-header">
            <h5>Daftar Member</h5>
          </div>
          <div class="card-body">
            <ul class="list-group list-group-flush">
              <% members.forEach(function(m) { %>
              <li class="list-group-item d-flex justify-content-between align-items-center">
                <%= m.name %>
                <span class="badge bg-secondary"><%= m.job || 'N/A' %></span>
              </li>
              <% }); %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<%- include('../../partials/footer') %>
