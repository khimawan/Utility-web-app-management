<%- include('../../partials/header') %>
  <%- include('../../partials/topnav') %>
  <div class="page-content">
    <div class="page-header">
      <h4><i class="bi bi-calendar-week me-2"></i>Halaman Jadwal Member</h4>
    </div>

    <div class="row">
      <div class="col-md-7">
        <div class="card mb-3">
          <div class="card-header d-flex justify-content-between align-items-center">
            <h5>Jadwal Shift</h5>
            <form method="GET" action="/awal/member" class="d-flex gap-2">
              <input type="date" name="date" class="form-control form-control-sm" value="<%= selectedDate %>">
              <button type="submit" class="btn btn-sm btn-primary"><i class="bi bi-search"></i></button>
            </form>
          </div>
          <div class="card-body">
            <div class="table-responsive">
              <table class="table table-sm table-striped">
                <thead>
                  <tr>
                    <th>Shift</th>
                    <th>Nama Member</th>
                    <th>Job</th>
                  </tr>
                </thead>
                <tbody>
                  <% ['1','2','3'].forEach(function(shift) { %>
                    <% schedules.filter(function(s) { return s.shift === shift; }).forEach(function(s, idx) { %>
                    <tr>
                      <% if (idx === 0) { %>
                        <td rowspan="<%= schedules.filter(function(s) { return s.shift === shift; }).length %>">
                          <span class="badge bg-primary">Shift <%= shift %></span>
                        </td>
                      <% } %>
                      <td><%= s.member_name || '-' %></td>
                      <td><span class="badge bg-info"><%= s.job %></span></td>
                    </tr>
                    <% }); %>
                    <% if (schedules.filter(function(s) { return s.shift === shift; }).length === 0) { %>
                    <tr>
                      <td><span class="badge bg-primary">Shift <%= shift %></span></td>
                      <td colspan="2" class="text-muted">Tidak ada jadwal</td>
                    </tr>
                    <% } %>
                  <% }); %>
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <div class="card">
          <div class="card-header">
            <h5>List Pengajuan Lembur</h5>
          </div>
          <div class="card-body">
            <div class="table-responsive">
              <table class="table table-sm table-striped">
                <thead>
                  <tr>
                    <th>Tanggal</th>
                    <th>Shift</th>
                    <th>Jenis</th>
                    <th>Member</th>
                    <th>Job</th>
                    <th>Status</th>
                    <th>Aksi</th>
                  </tr>
                </thead>
                <tbody>
                  <% submissions.forEach(function(s) { %>
                  <tr>
                    <td><%= s.overtime_date %></td>
                    <td><span class="badge bg-primary">Shift <%= s.shift %></span></td>
                    <td><%= s.schedule_type %></td>
                    <td><%= s.member_names || '-' %></td>
                    <td><span class="badge bg-info"><%= s.job %></span></td>
                    <td>
                      <% if (s.status === 'pending') { %>
                        <span class="badge bg-warning">Menunggu</span>
                      <% } else if (s.status === 'approved') { %>
                        <span class="badge bg-success">Disetujui</span>
                      <% } else { %>
                        <span class="badge bg-danger">Ditolak</span>
                      <% } %>
                    </td>
                    <td>
                      <% if (s.status === 'pending') { %>
                        <form method="POST" action="/awal/member/overtime/<%= s.id %>/delete" style="display:inline;" class="delete-btn-form">
                          <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                        </form>
                      <% } %>
                    </td>
                  </tr>
                  <% }); %>
                  <% if (submissions.length === 0) { %>
                  <tr><td colspan="7" class="text-center text-muted">Belum ada pengajuan lembur</td></tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>

      <div class="col-md-5">
        <div class="card mb-3">
          <div class="card-header">
            <h5>Ajukan Lembur</h5>
          </div>
          <div class="card-body">
            <form method="POST" action="/awal/member/overtime" id="overtimeForm">
              <div class="mb-3">
                <label class="form-label">Pilih Member</label>
                <div class="border rounded p-2" style="max-height: 200px; overflow-y: auto;">
                  <% members.forEach(function(m) { %>
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="member_ids" value="<%= m.id %>" id="member_<%= m.id %>">
                    <label class="form-check-label" for="member_<%= m.id %>"><%= m.name %></label>
                  </div>
                  <% }); %>
                </div>
              </div>
              <div class="mb-3">
                <label class="form-label">Tanggal Lembur</label>
                <input type="date" name="overtime_date" class="form-control" required>
              </div>
              <div class="mb-3">
                <label class="form-label">Shift</label>
                <select name="shift" class="form-select" required>
                  <option value="1">Shift 1</option>
                  <option value="2">Shift 2</option>
                  <option value="3">Shift 3</option>
                </select>
              </div>
              <div class="mb-3">
                <label class="form-label">Schedule Lembur</label>
                <select name="schedule_type" class="form-select" required>
                  <option value="">-- Pilih --</option>
                  <option value="H+6 (Hari Sabtu/1/2 Hari Kerja)">H+6 (Hari Sabtu/1/2 Hari Kerja)</option>
                  <option value="Libur Khusus (Hari Minggu/Libur Nasional)">Libur Khusus (Hari Minggu/Libur Nasional)</option>
                  <option value="Hari Biasa (Overtime)">Hari Biasa (Overtime)</option>
                </select>
              </div>
              <div class="mb-3">
                <label class="form-label">Job</label>
                <select name="job" class="form-select" required>
                  <option value="">-- Pilih --</option>
                  <option value="Operator WTP">Operator WTP</option>
                  <option value="Operator N2">Operator N2</option>
                  <option value="Facility">Facility</option>
                  <option value="Opsional">Opsional</option>
                </select>
              </div>
              <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary flex-fill"><i class="bi bi-send me-1"></i>Submit</button>
                <button type="button" class="btn btn-secondary flex-fill" onclick="document.getElementById('overtimeForm').reset()"><i class="bi bi-x-circle me-1"></i>Clear Form</button>
              </div>
            </form>
          </div>
        </div>

        <div class="card">
          <div class="card-header">
            <h5>Daftar Member</h5>
          </div>
          <div class="card-body">
            <ul class="list-group list-group-flush">
              <% members.forEach(function(m) { %>
              <li class="list-group-item d-flex justify-content-between align-items-center">
                <%= m.name %>
                <span class="badge bg-secondary"><%= m.job || 'N/A' %></span>
              </li>
              <% }); %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<%- include('../../partials/footer') %>
