<%- include('../../partials/header') %>
  <%- include('../../partials/topnav') %>
  <div class="page-content">
    <div class="page-header d-flex justify-content-between align-items-center">
      <h4><i class="bi bi-clipboard-check me-2"></i>Checklist Kompressor</h4>
      <a href="/job1" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Kembali</a>
    </div>

    <ul class="nav nav-tabs mb-3" id="kompressorTabs" role="tablist">
      <li class="nav-item" role="presentation">
        <button class="nav-link active" id="k01-tab" data-bs-toggle="tab" data-bs-target="#k01" type="button" role="tab" aria-controls="k01" aria-selected="true">
          <i class="bi bi-gear me-1"></i>Kompressor 01
        </button>
      </li>
      <li class="nav-item" role="presentation">
        <button class="nav-link" id="k02-tab" data-bs-toggle="tab" data-bs-target="#k02" type="button" role="tab" aria-controls="k02" aria-selected="false">
          <i class="bi bi-gear me-1"></i>Kompressor 02
        </button>
      </li>
    </ul>

    <div class="tab-content" id="kompressorTabContent">
      <!-- Kompressor 01 -->
      <div class="tab-pane fade show active" id="k01" role="tabpanel" aria-labelledby="k01-tab">
        <div class="row">
          <div class="col-md-5">
            <div class="card">
              <div class="card-header"><h5>Input Checklist Kompressor 01</h5></div>
              <div class="card-body">
                <form method="POST" action="/job1/checklist/kompressor/kompressor01">
                  <div class="mb-3">
                    <label class="form-label">Tanggal</label>
                    <input type="date" name="entry_date" class="form-control" required>
                  </div>
                  <div class="mb-3">
                    <label class="form-label">Shift</label>
                    <select name="shift" class="form-select" required>
                      <option value="1">Shift 1</option>
                      <option value="2">Shift 2</option>
                      <option value="3">Shift 3</option>
                    </select>
                  </div>
                  <% templates01.forEach(function(t) { %>
                  <div class="mb-3">
                    <label class="form-label"><%= t.parameter_name %> <% if (t.unit) { %>(<%= t.unit %>)<% } %></label>
                    <% if (t.parameter_type === 'number') { %>
                      <input type="number" step="any" name="values" class="form-control" min="<%= t.min_value %>" max="<%= t.max_value %>">
                    <% } else { %>
                      <input type="text" name="values" class="form-control">
                    <% } %>
                    <input type="hidden" name="templates" value="<%= t.id %>">
                  </div>
                  <% }); %>
                  <div class="mb-3">
                    <label class="form-label">Catatan</label>
                    <textarea name="notes" class="form-control" rows="2"></textarea>
                  </div>
                  <button type="submit" class="btn btn-primary w-100"><i class="bi bi-check-circle me-1"></i>Simpan Checklist</button>
                </form>
              </div>
            </div>
          </div>

          <div class="col-md-7">
            <div class="card">
              <div class="card-header"><h5>Riwayat Checklist Kompressor 01</h5></div>
              <div class="card-body">
                <div class="delete-selected-bar">
                  <button class="btn btn-sm btn-outline-danger" onclick="deleteSelected('/job1/checklist/delete-multiple')"><i class="bi bi-trash me-1"></i>Hapus Terpilih</button>
                </div>
                <div class="table-responsive scrollable-table">
                  <table class="table table-sm table-striped">
                    <thead>
                      <tr>
                        <th><input type="checkbox" class="select-all-checkbox"></th>
                        <th>Tanggal</th>
                        <th>Shift</th>
                        <th>Oleh</th>
                        <th>Aksi</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% entries01.forEach(function(e) { %>
                      <tr>
                        <td><input type="checkbox" class="row-checkbox" value="<%= e.id %>"></td>
                        <td><%= e.entry_date %></td>
                        <td><span class="badge bg-primary">Shift <%= e.shift %></span></td>
                        <td><%= e.input_by_name %></td>
                        <td>
                          <a href="/job1/checklist/entry/<%= e.id %>/delete" class="btn btn-sm btn-outline-danger delete-btn"><i class="bi bi-trash"></i></a>
                        </td>
                      </tr>
                      <% }); %>
                      <% if (entries01.length === 0) { %>
                      <tr><td colspan="5" class="text-center text-muted">Belum ada data</td></tr>
                      <% } %>
                    </tbody>
                  </table>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Kompressor 02 -->
      <div class="tab-pane fade" id="k02" role="tabpanel" aria-labelledby="k02-tab">
        <div class="row">
