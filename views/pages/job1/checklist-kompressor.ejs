                  </div>
                  <button type="submit" class="btn btn-primary w-100"><i class="bi bi-check-circle me-1"></i>Simpan Checklist</button>
                </form>
              </div>
            </div>
          </div>

          <div class="col-md-7">
            <div class="card">
              <div class="card-header"><h5>Riwayat Checklist Kompressor 02</h5></div>
              <div class="card-body">
                <div class="delete-selected-bar">
                  <button class="btn btn-sm btn-outline-danger" onclick="deleteSelected('/job1/checklist/delete-multiple')"><i class="bi bi-trash me-1"></i>Hapus Terpilih</button>
                </div>
                <div class="table-responsive scrollable-table">
                  <table class="table table-sm table-striped">
                    <thead>
