<%- include('../../partials/header') %>
<div class="main-content">
  <%- include('../../partials/topnav') %>
  <div class="page-content">
    <div class="page-header d-flex justify-content-between align-items-center">
      <h4><i class="bi bi-file-earmark-pdf me-2"></i>Working Instruction - Job 1</h4>
      <a href="/job1" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Kembali</a>
    </div>

    <div class="row">
      <% instructions.forEach(function(inst) { %>
      <div class="col-md-4 mb-3">
        <div class="card">
          <div class="card-body text-center">
            <i class="bi bi-file-earmark-pdf" style="font-size: 48px; color: #dc3545;"></i>
            <h5 class="mt-2"><%= inst.title %></h5>
            <p class="text-muted small"><%= inst.description || '' %></p>
            <a href="<%= inst.file_url %>" target="_blank" class="btn btn-primary btn-sm">
              <i class="bi bi-eye me-1"></i>Lihat PDF
            </a>
          </div>
        </div>
      </div>
      <% }); %>
      <% if (instructions.length === 0) { %>
      <div class="col-12">
        <div class="card">
          <div class="card-body text-center text-muted">
            <i class="bi bi-inbox" style="font-size: 48px;"></i>
            <p class="mt-2">Belum ada working instruction yang diupload.</p>
          </div>
        </div>
      </div>
      <% } %>
    </div>
  </div>
</div>
<%- include('../../partials/footer') %>
