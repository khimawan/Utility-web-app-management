                    <td><%= r.motor_gd7_temp ?? '-' %></td>
                    <td><%= r.mmf_inlet_pressure ?? '-' %></td>
                    <td><%= r.nilai_tds ?? '-' %></td>
                    <td><%= r.nilai_conductivity ?? '-' %></td>
                    <td><%= r.level_tandon_ro1 ?? '-' %></td>
                    <td><%= r.level_tandon_ro2 ?? '-' %></td>
