<%- include('../../partials/header') %>
  <%- include('../../partials/topnav') %>
  <div class="page-content">
    <div class="page-header d-flex justify-content-between align-items-center">
      <h4><i class="bi bi-clipboard-data me-2"></i>Rangkuman Kegiatan</h4>
      <form method="GET" action="/rangkuman" class="d-flex gap-2">
        <input type="date" name="date" class="form-control form-control-sm" value="<%= selectedDate %>">
        <button type="submit" class="btn btn-sm btn-primary"><i class="bi bi-search"></i></button>
      </form>
    </div>

    <div class="card mb-4">
      <div class="card-header"><h5>Tabel 1: Kegiatan Harian (Checklist & Pekerjaan)</h5></div>
      <div class="card-body">
        <div class="table-responsive">
          <table class="table table-striped table-hover">
            <thead>
              <tr>
                <th>Shift</th>
                <th>Nama Member</th>
                <th>Job</th>
                <th>Kegiatan</th>
                <th>Waktu</th>
              </tr>
            </thead>
            <tbody>
              <% checklists.forEach(function(c) { %>
              <tr>
                <td><span class="badge bg-primary">Shift <%= c.shift %></span></td>
                <td><%= c.input_by_name %></td>
                <td><span class="badge bg-info"><%= c.category %></span></td>
                <td>Pengisian Checklist</td>
                <td><%= c.created_at ? new Date(c.created_at).toLocaleTimeString('id-ID') : '-' %></td>
              </tr>
              <% }); %>
              <% warnings.forEach(function(w) { %>
              <tr>
                <td><span class="badge bg-warning text-dark">-</span></td>
                <td><%= w.member_names %></td>
                <td><span class="badge bg-warning text-dark">Warning</span></td>
                <td>Input Warning: <%= w.machine_name %></td>
                <td><%= w.created_at ? new Date(w.created_at).toLocaleTimeString('id-ID') : '-' %></td>
              </tr>
              <% }); %>
              <% works.forEach(function(w) { %>
              <tr>
                <td><span class="badge bg-success">-</span></td>
                <td><%= w.member_names %></td>
                <td><span class="badge bg-success">Facility</span></td>
                <td>Pekerjaan: <%= w.area %></td>
                <td><%= w.created_at ? new Date(w.created_at).toLocaleTimeString('id-ID') : '-' %></td>
              </tr>
              <% }); %>
              <% if (checklists.length === 0 && warnings.length === 0 && works.length === 0) { %>
              <tr><td colspan="5" class="text-center text-muted">Tidak ada kegiatan pada tanggal ini</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <div class="card mb-4">
      <div class="card-header"><h5>Tabel 2: Detail Pekerjaan Selesai</h5></div>
      <div class="card-body">
        <div class="table-responsive">
          <table class="table table-striped table-hover">
            <thead>
              <tr>
                <th>Pekerjaan</th>
                <th>Manpower</th>
                <th>Waktu</th>
                <th>Progres (%)</th>
                <th>Catatan</th>
              </tr>
            </thead>
            <tbody>
              <% works.forEach(function(w) { %>
              <tr>
                <td><strong><%= w.area %></strong> - <%= w.description %></td>
                <td><%= w.member_names %></td>
                <td><%= w.work_date %></td>
                <td><div class="progress" style="height:18px;width:80px;"><div class="progress-bar bg-success" style="width:<%= w.repair_percentage %>%"><%= w.repair_percentage %>%</div></div></td>
                <td><%= w.repair_notes || '-' %></td>
              </tr>
              <% }); %>
              <% if (works.length === 0) { %>
              <tr><td colspan="5" class="text-center text-muted">Tidak ada pekerjaan selesai pada tanggal ini</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-header"><h5>Tabel 3: Utility Request</h5></div>
      <div class="card-body">
        <div class="table-responsive">
          <table class="table table-striped table-hover">
            <thead>
              <tr>
                <th>Deskripsi Request</th>
                <th>Waktu</th>
                <th>Manpower</th>
                <th>Progress (%)</th>
                <th>Catatan</th>
              </tr>
            </thead>
            <tbody>
              <% utilityRequests.forEach(function(r) { %>
              <tr>
                <td><%= r.issue %></td>
                <td><%= r.created_at ? new Date(r.created_at).toLocaleString('id-ID') : '-' %></td>
                <td><%= r.member_names || '-' %></td>
                <td><div class="progress" style="height:18px;width:80px;"><div class="progress-bar bg-info" style="width:<%= r.repair_percentage %>%"><%= r.repair_percentage %>%</div></div></td>
                <td><%= r.repair_notes || '-' %></td>
              </tr>
              <% }); %>
              <% if (utilityRequests.length === 0) { %>
              <tr><td colspan="5" class="text-center text-muted">Tidak ada utility request pada tanggal ini</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>
<%- include('../../partials/footer') %>
