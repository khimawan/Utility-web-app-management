<%- include('../../partials/header') %>
  <%- include('../../partials/topnav') %>
  <div class="page-content">
    <div class="page-header d-flex justify-content-between align-items-center flex-wrap gap-2">
      <h4><i class="bi bi-box me-2"></i>Alat & Bahan</h4>
      <div class="d-flex gap-2">
        <a href="/inventory/download-template" class="btn btn-sm btn-outline-success"><i class="bi bi-download me-1"></i>Download Template CSV</a>
        <button class="btn btn-sm btn-outline-info" data-bs-toggle="modal" data-bs-target="#importCsvModal"><i class="bi bi-upload me-1"></i>Import CSV</button>
        <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addItemModal"><i class="bi bi-plus-circle me-1"></i>Tambah Item</button>
      </div>
    </div>

    <% if (typeof importCount !== 'undefined' && importCount > 0) { %>
      <div class="alert alert-success py-2"><i class="bi bi-check-circle me-1"></i><%= importCount %> item berhasil diimpor dari CSV.</div>
    <% } %>

    <ul class="nav nav-tabs mb-3">
      <li class="nav-item">
        <a class="nav-link active" data-bs-toggle="tab" href="#alat">Alat (<%= alat.length %>)</a>
      </li>
      <li class="nav-item">
        <a class="nav-link" data-bs-toggle="tab" href="#part">Part (<%= part.length %>)</a>
      </li>
      <li class="nav-item">
        <a class="nav-link" data-bs-toggle="tab" href="#bahan">Bahan (<%= bahan.length %>)</a>
      </li>
    </ul>

    <div class="tab-content">
      <% var tabs = [
        { id: 'alat', label: 'Alat', color: 'primary', data: alat, emptyColspan: 7 },
        { id: 'part', label: 'Part', color: 'info', data: part, emptyColspan: 7 },
        { id: 'bahan', label: 'Bahan', color: 'success', data: bahan, emptyColspan: 7 }
      ]; %>
      <% tabs.forEach(function(tab, idx) { %>
      <div class="tab-pane fade <%= idx === 0 ? 'show active' : '' %>" id="<%= tab.id %>">
        <div class="card">
          <div class="card-body">
            <div class="delete-selected-bar">
              <button class="btn btn-sm btn-outline-danger" onclick="deleteSelected('/inventory/delete-multiple')"><i class="bi bi-trash me-1"></i>Hapus Terpilih</button>
            </div>
            <div class="table-responsive scrollable-table">
              <table class="table table-striped table-hover">
                <thead>
                  <tr>
                    <th><input type="checkbox" class="select-all-checkbox"></th>
                    <th>Jenis</th>
                    <th>Nama</th>
                    <th>Spesifikasi</th>
                    <th>Jumlah</th>
                    <th>Foto</th>
                    <th>Aksi</th>
                  </tr>
                </thead>
                <tbody>
                  <% tab.data.forEach(function(item) { %>
                  <tr>
                    <td><input type="checkbox" class="row-checkbox" value="<%= item.id %>"></td>
                    <td><span class="badge bg-<%= tab.color %>"><%= tab.label %></span></td>
                    <td><strong><%= item.item_name %></strong></td>
                    <td><%= item.specification || '-' %></td>
                    <td><%= item.quantity %></td>
                    <td>
                      <% if (item.photo_url) { %>
                        <img src="<%= item.photo_url %>" width="50" height="50" style="object-fit:cover;border-radius:4px;">
                      <% } else { %>
                        -
                      <% } %>
                    </td>
                    <td>
                      <button class="btn btn-sm btn-outline-primary me-1 edit-item" data-id="<%= item.id %>" data-name="<%= item.item_name %>" data-spec="<%= item.specification %>" data-qty="<%= item.quantity %>" data-cat="<%= tab.id %>"><i class="bi bi-pencil"></i></button>
                      <form method="POST" action="/inventory/<%= item.id %>/delete" style="display:inline;" class="delete-btn-form">
                        <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                      </form>
                    </td>
                  </tr>
                  <% }); %>
                  <% if (tab.data.length === 0) { %>
                  <tr><td colspan="<%= tab.emptyColspan %>" class="text-center text-muted">Belum ada data <%= tab.label.toLowerCase() %></td></tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
      <% }); %>
    </div>

    <div class="modal fade" id="importCsvModal" tabindex="-1">
      <div class="modal-dialog">
        <div class="modal-content">
          <form method="POST" action="/inventory/import-csv" enctype="multipart/form-data">
            <div class="modal-header">
              <h5 class="modal-title">Import CSV Inventory</h5>
              <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
              <p class="text-muted small">Unduh template CSV terlebih dahulu, lalu isi data dan unggah kembali.</p>
              <div class="mb-3">
                <label class="form-label">File CSV</label>
                <input type="file" name="csv_file" class="form-control" accept=".csv" required>
              </div>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
              <button type="submit" class="btn btn-primary">Import</button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <div class="modal fade" id="addItemModal" tabindex="-1">
      <div class="modal-dialog">
        <div class="modal-content">
          <form method="POST" action="/inventory" enctype="multipart/form-data">
            <div class="modal-header">
              <h5 class="modal-title">Tambah Item</h5>
              <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
              <div class="mb-3">
                <label class="form-label">Kategori</label>
                <select name="category" class="form-select" required>
                  <option value="alat">Alat</option>
                  <option value="part">Part</option>
                  <option value="bahan">Bahan</option>
                </select>
              </div>
              <div class="mb-3">
                <label class="form-label">Nama Item</label>
                <input type="text" name="item_name" class="form-control" required>
              </div>
              <div class="mb-3">
                <label class="form-label">Spesifikasi</label>
                <textarea name="specification" class="form-control" rows="2"></textarea>
              </div>
              <div class="mb-3">
                <label class="form-label">Jumlah</label>
                <input type="number" name="quantity" class="form-control" min="0" value="0" required>
              </div>
              <div class="mb-3">
                <label class="form-label">Foto</label>
                <input type="file" name="photo" class="form-control" accept=".jpg,.jpeg,.png">
                <div class="form-text">Format: JPG, JPEG, PNG. Maks 5MB.</div>
              </div>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
              <button type="submit" class="btn btn-primary">Simpan</button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <div class="modal fade" id="editItemModal" tabindex="-1">
      <div class="modal-dialog">
        <div class="modal-content">
          <form method="POST" id="editItemForm" enctype="multipart/form-data">
            <div class="modal-header">
              <h5 class="modal-title">Edit Item</h5>
              <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
              <div class="mb-3">
                <label class="form-label">Nama Item</label>
                <input type="text" name="item_name" class="form-control" id="edit_item_name" required>
              </div>
              <div class="mb-3">
                <label class="form-label">Spesifikasi</label>
                <textarea name="specification" class="form-control" rows="2" id="edit_item_spec"></textarea>
              </div>
              <div class="mb-3">
                <label class="form-label">Jumlah</label>
                <input type="number" name="quantity" class="form-control" id="edit_item_qty" min="0" required>
              </div>
              <div class="mb-3">
                <label class="form-label">Ganti Foto</label>
                <input type="file" name="photo" class="form-control" accept=".jpg,.jpeg,.png">
                <div class="form-text">Format: JPG, JPEG, PNG. Maks 5MB.</div>
              </div>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
              <button type="submit" class="btn btn-primary">Simpan</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
document.querySelectorAll('.edit-item').forEach(function(btn) {
  btn.addEventListener('click', function() {
    document.getElementById('editItemForm').action = '/inventory/' + this.dataset.id;
    document.getElementById('edit_item_name').value = this.dataset.name;
    document.getElementById('edit_item_spec').value = this.dataset.spec || '';
    document.getElementById('edit_item_qty').value = this.dataset.qty;
    new bootstrap.Modal(document.getElementById('editItemModal')).show();
  });
});
</script>
<%- include('../../partials/footer') %>