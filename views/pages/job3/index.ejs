<%- include('../../partials/header') %>
<div class="main-content">
  <%- include('../../partials/topnav') %>
  <div class="page-content">
    <div class="page-header">
      <h4><i class="bi bi-gear me-2"></i>Job 3 - Facility</h4>
    </div>

    <div class="profile-section">
      <h3><i class="bi bi-info-circle me-2"></i>Deskripsi Job Facility</h3>
      <% if (description.length > 0) { %>
        <p class="text-muted"><%= description[0].description %></p>
      <% } %>
    </div>

    <div class="profile-section">
      <h3><i class="bi bi-cpu me-2"></i>Scope Pekerjaan Facility</h3>
      <div class="row">
        <% machines.forEach(function(m) { %>
        <div class="col-md-4 mb-3">
          <div class="card">
            <div class="card-body text-center">
              <i class="bi bi-tools" style="font-size: 48px; color: #1e3c72;"></i>
              <h5 class="mt-2"><%= m.name %></h5>
              <p class="text-muted small"><%= m.description %></p>
            </div>
          </div>
        </div>
        <% }); %>
      </div>
    </div>

    <div class="row">
      <div class="col-md-3 mb-3">
        <a href="/job3/checklist/pemakaian_air" class="card text-decoration-none">
          <div class="card-body text-center">
            <i class="bi bi-droplet" style="font-size: 36px; color: #17a2b8;"></i>
            <h5 class="mt-2">Checklist Pemakaian Air</h5>
          </div>
        </a>
      </div>
      <div class="col-md-3 mb-3">
        <a href="/job3/checklist/pemakaian_gas" class="card text-decoration-none">
          <div class="card-body text-center">
            <i class="bi bi-fire" style="font-size: 36px; color: #fd7e14;"></i>
            <h5 class="mt-2">Checklist Pemakaian Gas</h5>
          </div>
        </a>
      </div>
      <div class="col-md-3 mb-3">
        <a href="/job3/checklist/suhu_trafo" class="card text-decoration-none">
          <div class="card-body text-center">
            <i class="bi bi-thermometer-half" style="font-size: 36px; color: #dc3545;"></i>
            <h5 class="mt-2">Checklist Suhu Trafo</h5>
          </div>
        </a>
      </div>
      <div class="col-md-3 mb-3">
        <a href="/job3/checklist/listrik_trafo" class="card text-decoration-none">
          <div class="card-body text-center">
            <i class="bi bi-lightning" style="font-size: 36px; color: #ffc107;"></i>
            <h5 class="mt-2">Checklist Listrik Trafo</h5>
          </div>
        </a>
      </div>
      <div class="col-md-6 mb-3">
        <a href="/job3/works" class="card text-decoration-none">
          <div class="card-body text-center">
            <i class="bi bi-clipboard-check" style="font-size: 36px; color: #28a745;"></i>
            <h5 class="mt-2">Input Pekerjaan</h5>
          </div>
        </a>
      </div>
    </div>

    <% if (works.length > 0) { %>
    <div class="card">
      <div class="card-header"><h5>Pekerjaan Terbaru</h5></div>
      <div class="card-body">
        <div class="table-responsive">
          <table class="table table-sm table-striped">
            <thead><tr><th>Tanggal</th><th>Area</th><th>Deskripsi</th><th>Progres</th></tr></thead>
            <tbody>
              <% works.forEach(function(w) { %>
              <tr>
                <td><%= w.work_date %></td>
                <td><%= w.area %></td>
                <td><%= w.description %></td>
                <td><div class="progress" style="height:18px;width:80px;"><div class="progress-bar bg-success" style="width:<%= w.repair_percentage %>%"><%= w.repair_percentage %>%</div></div></td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
    <% } %>
  </div>
</div>
<%- include('../../partials/footer') %>
