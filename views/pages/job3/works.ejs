<%- include('../../partials/header') %>
  <%- include('../../partials/topnav') %>
  <div class="page-content">
    <div class="page-header d-flex justify-content-between align-items-center">
      <h4><i class="bi bi-clipboard-check me-2"></i>Input Pekerjaan - Facility</h4>
      <a href="/job3" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Kembali</a>
    </div>

    <div class="row">
      <div class="col-md-5">
        <div class="card">
          <div class="card-header"><h5>Form Pekerjaan</h5></div>
          <div class="card-body">
            <form method="POST" action="/job3/works">
              <div class="mb-3">
                <label class="form-label">Tanggal</label>
                <input type="date" name="work_date" class="form-control" required>
              </div>
              <div class="mb-3">
                <label class="form-label">Area Pekerjaan</label>
                <input type="text" name="area" class="form-control" required>
              </div>
              <div class="mb-3">
                <label class="form-label">Deskripsi Pekerjaan</label>
                <textarea name="description" class="form-control" rows="3" required></textarea>
              </div>
              <div class="mb-3">
                <label class="form-label">Pilih Member</label>
                <div class="border rounded p-3" style="max-height: 200px; overflow-y: auto;">
                  <% members.forEach(function(m) { %>
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="member_ids" value="<%= m.id %>" id="add_member_<%= m.id %>">
                    <label class="form-check-label" for="add_member_<%= m.id %>">
                      <%= m.name %> <span class="badge bg-secondary ms-1"><%= m.job || 'N/A' %></span>
                    </label>
                  </div>
                  <% }); %>
                </div>
              </div>
              <div class="mb-3">
                <label class="form-label">Catatan Perbaikan</label>
                <textarea name="repair_notes" class="form-control" rows="2"></textarea>
              </div>
              <div class="mb-3">
                <label class="form-label">Persentase Perbaikan (%)</label>
                <input type="number" name="repair_percentage" class="form-control" min="0" max="100" value="0">
              </div>
              <button type="submit" class="btn btn-primary w-100"><i class="bi bi-check-circle me-1"></i>Simpan Pekerjaan</button>
            </form>
          </div>
        </div>
      </div>

      <div class="col-md-7">
        <div class="card">
          <div class="card-header"><h5>Riwayat Pekerjaan</h5></div>
          <div class="card-body">
            <div class="table-responsive">
              <table class="table table-sm table-striped">
                <thead>
                  <tr><th>Tanggal</th><th>Area</th><th>Deskripsi</th><th>Member</th><th>Progres</th><th>Aksi</th></tr>
                </thead>
                <tbody>
                  <% works.forEach(function(w) { %>
                  <tr>
                    <td><%= w.work_date %></td>
                    <td><strong><%= w.area %></strong></td>
                    <td><%= w.description %></td>
                    <td><%= w.member_names || '-' %></td>
                    <td><div class="progress" style="height:18px;width:80px;"><div class="progress-bar bg-success" style="width:<%= w.repair_percentage %>%"><%= w.repair_percentage %>%</div></div></td>
                    <td>
                      <button class="btn btn-sm btn-outline-primary me-1 edit-work"
                        data-id="<%= w.id %>"
                        data-date="<%= w.work_date %>"
                        data-area="<%= w.area %>"
                        data-desc="<%= w.description %>"
                        data-notes="<%= w.repair_notes || '' %>"
                        data-percentage="<%= w.repair_percentage %>"
                        data-memberids="<%= w.member_names || '' %>">
                        <i class="bi bi-pencil"></i>
                      </button>
                      <form method="POST" action="/job3/works/<%= w.id %>/delete" style="display:inline;" class="delete-btn-form">
                        <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                      </form>
                    </td>
                  </tr>
                  <% }); %>
                  <% if (works.length === 0) { %>
                  <tr><td colspan="6" class="text-center text-muted">Belum ada data</td></tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="modal fade" id="editWorkModal" tabindex="-1">
      <div class="modal-dialog">
        <div class="modal-content">
          <form method="POST" id="editWorkForm">
            <div class="modal-header">
              <h5 class="modal-title">Edit Pekerjaan</h5>
              <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
              <div class="mb-3">
                <label class="form-label">Tanggal</label>
                <input type="date" name="work_date" class="form-control" id="edit_work_date" required>
              </div>
              <div class="mb-3">
                <label class="form-label">Area Pekerjaan</label>
                <input type="text" name="area" class="form-control" id="edit_work_area" required>
              </div>
              <div class="mb-3">
                <label class="form-label">Deskripsi Pekerjaan</label>
                <textarea name="description" class="form-control" rows="3" id="edit_work_desc" required></textarea>
              </div>
              <div class="mb-3">
                <label class="form-label">Pilih Member</label>
                <div class="border rounded p-3" style="max-height: 200px; overflow-y: auto;">
                  <% members.forEach(function(m) { %>
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="member_ids" value="<%= m.id %>" id="edit_member_<%= m.id %>">
                    <label class="form-check-label" for="edit_member_<%= m.id %>">
                      <%= m.name %> <span class="badge bg-secondary ms-1"><%= m.job || 'N/A' %></span>
                    </label>
                  </div>
                  <% }); %>
                </div>
              </div>
              <div class="mb-3">
                <label class="form-label">Catatan Perbaikan</label>
                <textarea name="repair_notes" class="form-control" rows="2" id="edit_work_notes"></textarea>
              </div>
              <div class="mb-3">
                <label class="form-label">Persentase Perbaikan (%)</label>
                <input type="number" name="repair_percentage" class="form-control" min="0" max="100" id="edit_work_percentage">
              </div>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
              <button type="submit" class="btn btn-primary">Update</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
document.querySelectorAll('.edit-work').forEach(function(btn) {
  btn.addEventListener('click', function() {
    document.getElementById('editWorkForm').action = '/job3/works/' + this.dataset.id;
    document.getElementById('edit_work_date').value = this.dataset.date;
    document.getElementById('edit_work_area').value = this.dataset.area;
    document.getElementById('edit_work_desc').value = this.dataset.desc;
    document.getElementById('edit_work_notes').value = this.dataset.notes;
    document.getElementById('edit_work_percentage').value = this.dataset.percentage;

    document.querySelectorAll('#editWorkModal input[name="member_ids"]').forEach(function(cb) {
      cb.checked = false;
    });

    var memberNames = this.dataset.memberids;
    if (memberNames) {
      var names = memberNames.split(', ');
      names.forEach(function(name) {
        document.querySelectorAll('#editWorkModal .form-check-label').forEach(function(label) {
          if (label.textContent.trim().startsWith(name.trim())) {
            label.previousElementSibling.checked = true;
          }
        });
      });
    }

    new bootstrap.Modal(document.getElementById('editWorkModal')).show();
  });
});
</script>
<%- include('../../partials/footer') %>
