<%- include('../../partials/header') %>
  <%- include('../../partials/topnav') %>
  <div class="page-content">
    <div class="page-header">
      <h4><i class="bi bi-calendar me-2"></i>Kelola Jadwal</h4>
    </div>
    <div class="card">
      <div class="card-header">
        <form method="GET" action="/admin/schedules" class="d-flex gap-2">
          <input type="date" name="date" class="form-control form-control-sm" value="<%= selectedDate %>">
          <button type="submit" class="btn btn-sm btn-primary"><i class="bi bi-search"></i> Cari</button>
        </form>
      </div>
      <div class="card-body">
        <form method="POST" action="/admin/schedules" class="row g-2 mb-3">
          <input type="hidden" name="schedule_date" value="<%= selectedDate %>">
          <div class="col-md-2">
            <select name="shift" class="form-select form-select-sm" required>
              <option value="1">Shift 1</option>
              <option value="2">Shift 2</option>
              <option value="3">Shift 3</option>
            </select>
          </div>
          <div class="col-md-3">
            <select name="member_id" class="form-select form-select-sm" required>
              <% members.filter(function(m) { return m.position === 'member'; }).forEach(function(m) { %>
              <option value="<%= m.id %>"><%= m.name %></option>
              <% }); %>
            </select>
          </div>
          <div class="col-md-3">
            <select name="job" class="form-select form-select-sm" required>
              <option value="operator_wtp">Operator WTP</option>
              <option value="operator_n2">Operator N2</option>
              <option value="facility">Facility</option>
            </select>
          </div>
          <div class="col-md-2">
            <button type="submit" class="btn btn-primary btn-sm w-100"><i class="bi bi-plus-circle me-1"></i>Tambah</button>
          </div>
        </form>
        <div class="table-responsive">
          <table class="table table-striped">
            <thead><tr><th>Shift</th><th>Member</th><th>Job</th><th>Aksi</th></tr></thead>
            <tbody>
              <% schedules.forEach(function(s) { %>
              <tr>
                <td><span class="badge bg-primary">Shift <%= s.shift %></span></td>
                <td><%= s.member_name %></td>
                <td><%= s.job %></td>
                <td>
                  <form method="POST" action="/admin/schedules/<%= s.id %>/delete" style="display:inline;" class="delete-btn-form">
                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                  </form>
                </td>
              </tr>
              <% }); %>
              <% if (schedules.length === 0) { %>
              <tr><td colspan="4" class="text-center text-muted">Tidak ada jadwal untuk tanggal ini</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>
<%- include('../../partials/footer') %>
