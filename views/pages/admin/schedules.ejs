<%- include('../../partials/header') %>
  <%- include('../../partials/topnav') %>
  <div class="page-content">
    <div class="page-header">
      <h4><i class="bi bi-calendar me-2"></i>Kelola Jadwal</h4>
    </div>
    <div class="card">
      <div class="card-header">
        <form method="GET" action="/admin/schedules" class="d-flex gap-2">
          <input type="date" name="date" class="form-control form-control-sm" value="<%= selectedDate %>">
          <button type="submit" class="btn btn-sm btn-primary"><i class="bi bi-search"></i> Cari</button>
        </form>
      </div>
      <div class="card-body">
        <div class="table-responsive">
          <table class="table table-striped">
            <thead><tr><th>Shift</th><th>Member</th><th>Job</th><th>Aksi</th></tr></thead>
            <tbody>
              <% schedules.forEach(function(s) { %>
              <tr>
                <td><span class="badge bg-primary">Shift <%= s.shift %></span></td>
                <td><%= s.member_name %></td>
                <td><%= s.job %></td>
                <td>
                  <form method="POST" action="/admin/schedules/<%= s.id %>/delete" style="display:inline;" class="delete-btn-form">
                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                  </form>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>
<%- include('../../partials/footer') %>
