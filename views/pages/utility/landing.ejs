<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Utility Management - Pengajuan Bantuan</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%); min-height: 100vh; }
    .hero-section { min-height: 100vh; display: flex; align-items: center; justify-content: center; }
    .card-feature { transition: transform 0.3s, box-shadow 0.3s; border: none; border-radius: 16px; }
    .card-feature:hover { transform: translateY(-8px); box-shadow: 0 12px 40px rgba(0,0,0,0.2); }
    .btn-hero { border-radius: 12px; padding: 16px 32px; font-size: 18px; font-weight: 600; transition: all 0.3s; }
    .welcome-image { max-height: 300px; border-radius: 16px; object-fit: cover; }
  </style>
</head>
<body>
  <div class="hero-section">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-lg-8 text-center text-white">
          <% if (content.welcome_image && content.welcome_image.content_image) { %>
            <img src="<%= content.welcome_image.content_image %>" alt="Utility" class="welcome-image mb-4" onerror="this.style.display='none'">
          <% } %>
          <h1 class="display-4 fw-bold mb-3"><%= content.welcome_title ? content.welcome_title.content_value : 'Selamat Datang di Sistem Utility' %></h1>
          <h3 class="mb-3 fw-light"><%= content.welcome_subtitle ? content.welcome_subtitle.content_value : 'Pengajuan Bantuan & Tracking Pekerjaan Utility' %></h3>
          <p class="lead mb-5"><%= content.welcome_description ? content.welcome_description.content_value : 'Sistem ini memudahkan Anda untuk mengajukan bantuan terkait utility dan memantau progress pengerjaannya secara realtime.' %></p>

          <div class="row g-4 justify-content-center">
            <div class="col-md-5">
              <div class="card card-feature p-4 h-100">
                <div class="card-body text-center">
                  <i class="bi bi-clipboard-plus display-1 text-primary mb-3"></i>
                  <h4 class="card-title fw-bold">Input Pengajuan</h4>
                  <p class="card-text text-muted">Ajukan permintaan bantuan utility dengan mengisi form pengajuan secara lengkap.</p>
                  <a href="/utility/submit" class="btn btn-primary btn-hero w-100 mt-3">
                    <i class="bi bi-plus-circle me-2"></i><%= content.btn_submit_text ? content.btn_submit_text.content_value : 'Input Pengajuan' %>
                  </a>
                </div>
              </div>
            </div>
            <div class="col-md-5">
              <div class="card card-feature p-4 h-100">
                <div class="card-body text-center">
                  <i class="bi bi-search display-1 text-success mb-3"></i>
                  <h4 class="card-title fw-bold">Tracking Pengajuan</h4>
                  <p class="card-text text-muted">Pantau status dan progress pengajuan bantuan utility Anda secara realtime.</p>
                  <a href="/utility/tracking" class="btn btn-success btn-hero w-100 mt-3">
                    <i class="bi bi-eye me-2"></i><%= content.btn_tracking_text ? content.btn_tracking_text.content_value : 'Tracking Pengajuan' %>
                  </a>
                </div>
              </div>
            </div>
          </div>

          <div class="mt-5">
            <a href="/login" class="text-white-50 text-decoration-none"><i class="bi bi-box-arrow-in-right me-1"></i>Admin / Member Login</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
